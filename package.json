{
  "name": "modudoc",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:release": "tauri build --config src-tauri/tauri.release.conf.json",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "notice:write": "node scripts/generate-third-party-notices.mjs --write",
    "notice:check": "node scripts/generate-third-party-notices.mjs --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "e2e": "wdio run e2e-tests/wdio.conf.ts",
    "e2e:xvfb": "env -u WAYLAND_DISPLAY -u XDG_SESSION_TYPE GDK_BACKEND=x11 MODUDOC_E2E_DIAG=1 xvfb-run --auto-servernum -- wdio run e2e-tests/wdio.conf.ts"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "6.5.0",
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/modifiers": "9.0.0",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@fontsource/inter": "5.2.8",
    "@fontsource/jetbrains-mono": "5.2.8",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-switch": "1.2.6",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-tooltip": "1.2.8",
    "@tauri-apps/api": "2.11.0",
    "@tauri-apps/plugin-dialog": "2.7.1",
    "@tauri-apps/plugin-opener": "2.5.4",
    "@uiw/codemirror-theme-github": "4.25.10",
    "@uiw/react-codemirror": "4.25.10",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.16.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1",
    "tailwind-merge": "3.6.0",
    "zustand": "5.0.13"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.3.0",
    "@tauri-apps/cli": "2.11.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@wdio/cli": "9.27.1",
    "@wdio/globals": "9.27.1",
    "@wdio/local-runner": "9.27.1",
    "@wdio/mocha-framework": "9.27.1",
    "@wdio/spec-reporter": "9.27.1",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-icu": "^2.4.3",
    "jsdom": "29.1.1",
    "react-i18next": "^17.0.8",
    "tsx": "4.22.3",
    "typescript": "6.0.3",
    "vite": "8.0.14",
